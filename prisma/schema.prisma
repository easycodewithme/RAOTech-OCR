// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  plan      Plan     @default(FREE)
  role      UserRole @default(CA)

  activeClientId String?
  activeClient   Client? @relation("ActiveClient", fields: [activeClientId], references: [id], onDelete: SetNull)

  clients        Client[]        @relation("OwnedClients")
  memberships    ClientMember[]
  invoices       Invoice[]
  ledgers        Ledger[]
  ledgerMappings LedgerMapping[]
  mappingRules   MappingRule[]
  vouchers       Voucher[]
  bankStatements BankStatement[]
  gst2bUploads   Gst2bUpload[]
  tallyExports   TallyExport[]
  tasks          Task[]          @relation("AssignedTasks")
  intakeLinks    IntakeLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id           String  @id @default(uuid())
  userId       String
  user         User    @relation("OwnedClients", fields: [userId], references: [id], onDelete: Cascade)
  name         String
  gstin        String?
  pan          String?
  address      String?
  email        String?
  phone        String?
  tallyCompany String?
  isDefault    Boolean @default(false)

  activeForUsers User[]          @relation("ActiveClient")
  members        ClientMember[]
  invoices       Invoice[]
  ledgers        Ledger[]
  ledgerMappings LedgerMapping[]
  mappingRules   MappingRule[]
  vouchers       Voucher[]
  bankStatements BankStatement[]
  gst2bUploads   Gst2bUpload[]
  tallyExports   TallyExport[]
  intakeLinks    IntakeLink[]
  tasks          Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model ClientMember {
  id       String       @id @default(uuid())
  clientId String
  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     MemberRole   @default(CLERK)

  createdAt DateTime @default(now())

  @@unique([clientId, userId])
  @@index([userId])
}

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  fileUrl        String
  status         InvoiceStatus @default(PENDING)

  invoiceNumber  String?
  date           DateTime?
  totalAmount    Float?
  taxAmount      Float?

  vendor         String?
  vendorGstin    String?
  vendorAddress  String?
  vendorPhone    String?

  customerName   String?
  customerGstin  String?

  subtotal       Float?
  cgst           Float?
  sgst           Float?
  igst           Float?
  discount       Float?

  gstValid       Boolean?
  gstState       String?
  validationFlags Json?

  ocrEngine      String?
  processingTime Float?

  extractedData  Json?
  items          Json?

  documentType   String? // PURCHASE | SALE | CREDIT_NOTE | DEBIT_NOTE | RECEIPT | BANK
  isDuplicate    Boolean @default(false)
  duplicateOfId  String?

  // E-invoice / e-way bill (optional fields)
  irn            String?
  ackNo          String?
  ewayBillNo     String?

  voucher        Voucher?
  reconMatches   GstReconMatch[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, clientId])
  @@index([clientId, invoiceNumber, vendorGstin])
  @@index([clientId, status])
}

model Ledger {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  group       LedgerGroup
  ledgerType  LedgerType
  gstRate     Float?
  isSeeded    Boolean     @default(false)
  isSystem    Boolean     @default(false)
  parentGstin String?

  mappings     LedgerMapping[]
  ruleTargets  MappingRule[]
  voucherLines VoucherLine[]
  bankTxns     BankTxn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId, name])
  @@index([userId, clientId, ledgerType])
}

model LedgerMapping {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  clientId   String
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  matchType  MatchKeyType // GSTIN | VENDOR_NAME | NARRATION
  matchKey   String
  ledgerId   String
  ledger     Ledger       @relation(fields: [ledgerId], references: [id])

  hitCount   Int      @default(1)
  lastUsedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId, matchType, matchKey])
  @@index([userId, clientId, matchType, matchKey])
}

model MappingRule {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ruleType RuleType
  pattern  String
  ledgerId String
  ledger   Ledger   @relation(fields: [ledgerId], references: [id])

  priority Int     @default(100)
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clientId, enabled, priority])
}

model Voucher {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  invoiceId String  @unique
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  voucherType VoucherType
  status      VoucherStatus @default(DRAFT)
  date        DateTime
  narration   String?

  totalDebit  Float
  totalCredit Float
  roundOff    Float @default(0)

  avgConfidence Float?
  exportedAt    DateTime?
  approvedAt    DateTime?
  approvedBy    String?

  lines VoucherLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clientId, status])
  @@index([userId, clientId, voucherType, date])
}

model VoucherLine {
  id        String  @id @default(uuid())
  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  ledgerId           String?
  ledger             Ledger?  @relation(fields: [ledgerId], references: [id])
  ledgerNameSnapshot String?

  role       LineRole
  debit      Float      @default(0)
  credit     Float      @default(0)

  confidence Float?
  mappedVia  MappedVia?
  hsnCode    String?
  gstRate    Float?
  sortOrder  Int        @default(0)

  @@index([voucherId])
  @@index([ledgerId])
}

model BankStatement {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  fileName      String
  bankName      String?
  accountNumber String?
  bankLedgerId  String?
  status        String   @default("DRAFT") // DRAFT | SYNCED | EXPORTED_DEMO

  txns          BankTxn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clientId, status])
}

model BankTxn {
  id          String        @id @default(uuid())
  statementId String
  statement   BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  date        DateTime?
  description String
  refNo       String?
  withdrawal  Float    @default(0)
  deposit     Float    @default(0)
  balance     Float?

  classification BankTxnClass?
  ledgerId           String?
  ledger             Ledger?  @relation(fields: [ledgerId], references: [id])
  ledgerNameSnapshot String?
  confidence         Float?
  sortOrder          Int      @default(0)

  @@index([statementId])
  @@index([ledgerId])
}

model Gst2bUpload {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  fileName   String
  period     String?  // YYYY-MM
  rowCount   Int      @default(0)
  matched    Int      @default(0)
  mismatched Int      @default(0)
  missingBooks Int    @default(0)
  missing2b  Int      @default(0)
  itcEligible Float   @default(0)
  itcAtRisk  Float    @default(0)
  rawSummary Json?

  rows       Gst2bRow[]
  matches    GstReconMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clientId])
}

model Gst2bRow {
  id         String      @id @default(uuid())
  uploadId   String
  upload     Gst2bUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  supplierGstin String?
  supplierName  String?
  invoiceNumber String?
  invoiceDate   DateTime?
  taxableValue  Float     @default(0)
  igst          Float     @default(0)
  cgst          Float     @default(0)
  sgst          Float     @default(0)
  cess          Float     @default(0)
  totalTax      Float     @default(0)
  invoiceType   String?
  raw           Json?

  match         GstReconMatch?

  @@index([uploadId])
  @@index([supplierGstin, invoiceNumber])
}

model GstReconMatch {
  id          String      @id @default(uuid())
  uploadId    String
  upload      Gst2bUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  gst2bRowId  String?     @unique
  gst2bRow    Gst2bRow?   @relation(fields: [gst2bRowId], references: [id], onDelete: SetNull)
  invoiceId   String?
  invoice     Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  status      ReconStatus
  taxableDiff Float       @default(0)
  taxDiff     Float       @default(0)
  notes       String?

  createdAt DateTime @default(now())

  @@index([uploadId, status])
}

model TallyExport {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  voucherIds   String[]
  fileName     String
  voucherCount Int      @default(0)
  ledgerCount  Int      @default(0)
  status       String   @default("EXPORTED_DEMO")

  createdAt DateTime @default(now())

  @@index([userId, clientId])
}

model IntakeLink {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token     String   @unique @default(uuid())
  label     String?
  enabled   Boolean  @default(true)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation("AssignedTasks", fields: [userId], references: [id])
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    Int        @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clientId, status])
}

enum UserRole {
  CA
  CLERK
  CLIENT
}

enum MemberRole {
  CA
  CLERK
  CLIENT
}

enum LedgerGroup {
  SUNDRY_CREDITORS
  SUNDRY_DEBTORS
  DUTIES_AND_TAXES
  PURCHASE_ACCOUNTS
  SALES_ACCOUNTS
  DIRECT_EXPENSES
  INDIRECT_EXPENSES
  INDIRECT_INCOME
  BANK_ACCOUNTS
  CASH_IN_HAND
  CURRENT_ASSETS
  CURRENT_LIABILITIES
  FIXED_ASSETS
}

enum LedgerType {
  PARTY
  PURCHASE
  SALE
  TAX_INPUT
  TAX_OUTPUT
  EXPENSE
  INCOME
  ROUND_OFF
  BANK
  CASH
  OTHER
}

enum MatchKeyType {
  GSTIN
  VENDOR_NAME
  NARRATION
}

enum RuleType {
  GSTIN_EQUALS
  VENDOR_NAME_CONTAINS
  VENDOR_NAME_EQUALS
  HSN_EQUALS
}

enum VoucherType {
  PURCHASE
  SALE
  JOURNAL
  CREDIT_NOTE
  DEBIT_NOTE
  PAYMENT
  RECEIPT
  CONTRA
}

enum VoucherStatus {
  DRAFT
  APPROVED
  POSTED
  EXPORTED_DEMO
}

enum LineRole {
  PARTY
  ITEM
  CGST
  SGST
  IGST
  ROUND_OFF
  DISCOUNT
}

enum MappedVia {
  RULE
  GSTIN_MEMORY
  NAME_MEMORY
  NARRATION_MEMORY
  FUZZY
  MANUAL
  DEFAULT
}

enum BankTxnClass {
  PAYMENT
  RECEIPT
  CONTRA
}

enum ReconStatus {
  MATCHED
  VALUE_MISMATCH
  MISSING_IN_2B
  MISSING_IN_BOOKS
  DUPLICATE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum InvoiceStatus {
  PENDING
  PROCESSED
  FAILED
}
